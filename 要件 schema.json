{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cashflow Game Database Schema (Updated)",
  "description": "Supabase上のroomsテーブルおよびparticipantsテーブルの厳密なデータ構造と、給料日マスの通過判定ロジック定義",
  "type": "object",
  "properties": {
    "board_settings": {
      "type": "object",
      "description": "ゲームの盤面設定およびルール定義",
      "properties": {
        "rat_race": {
          "type": "object",
          "properties": {
            "payday_cells": { 
              "type": "array", 
              "items": { "type": "number" }, 
              "default": [0, 5, 11, 18],
              "description": "給料日マスの位置（0-23）"
            },
            "payday_rule": { 
              "type": "string", 
              "enum": ["passing_or_landing"],
              "description": "通過または着地で発動するルール定義"
            }
          }
        }
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "current_turn_user_id": { "type": ["string", "null"] },
          "game_state": {
            "type": "object",
            "properties": {
              "current_card": {
                "type": ["object", "null"],
                "properties": {
                  "status": { "type": "string", "enum": ["active", "completed"] },
                  "owner_user_id": { "type": "string" },
                  "deck_type": { "type": "string" },
                  "title": { "type": "string" },
                  "cost": { "type": "number" },
                  "down_payment": { "type": "number" },
                  "mortgage": { "type": "number" },
                  "passive_income": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "room_id": { "type": "string" },
          "user_id": { "type": "string" },
          "state": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string", "enum": ["一般", "ホスト"] },
              "profession": { "type": "string" },
              "track": { "type": "string", "enum": ["rat_race", "fast_track"] },
              "position": { "type": "number", "minimum": 0, "maximum": 23 },
              "last_dice": { 
                "type": "number", 
                "minimum": 0, 
                "maximum": 6,
                "description": "プレイヤーが最後に振ったサイコロの出目。手番開始時（プリロール）に必ず 0 にリセットすること。UI側で >0 の場合は『ポストロール状態』と判定し、同一手番内の不正な再ロールを防止する厳密なトリガーとして運用する。"
              },
              "is_calculating": { 
                "type": "boolean", 
                "description": "財務変動直後の手番ロックフラグ。検証成功でfalseに更新。" 
              },
              "calculation_phase": { 
                "type": "string", 
                "enum": ["income_tax", "payday", "deal", "none"] 
              },
              "children_count": { "type": "number", "minimum": 0, "maximum": 3 },
              "charity_turns_left": { "type": "number", "minimum": 0 },
              "downsized_turns_left": { "type": "number", "minimum": 0 },
              "financials": {
                "type": "object",
                "properties": {
                  "cash": { "type": "number" },
                  "cashflow": { "type": "number" },
                  "income": {
                    "type": "object",
                    "properties": {
                      "salary": { "type": "number" },
                      "passive": { "type": "number" },
                      "total": { "type": "number" }
                    }
                  },
                  "expenses": {
                    "type": "object",
                    "properties": {
                      "taxes": { "type": "number" },
                      "mortgage_payment": { "type": "number" },
                      "car_loan_payment": { "type": "number" },
                      "other": { "type": "number" },
                      "total": { "type": "number" }
                    }
                  },
                  "assets": {
                    "type": "object",
                    "properties": {
                      "stocks": { "type": "object" },
                      "real_estate": { "type": "object" }
                    }
                  },
                  "liabilities": {
                    "type": "object",
                    "properties": {
                      "mortgage": { "type": "number" },
                      "car_loan": { "type": "number" },
                      "retail_debt": { "type": "number" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["board_settings", "rooms", "participants"]
}
