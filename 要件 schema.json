{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cashflow Game Database Schema (Updated)",
  "description": "Supabase上のrooms, participants, cardsテーブルの厳密なデータ構造とロジック定義",
  "type": "object",
  "properties": {
    "board_settings": {
      "type": "object",
      "description": "ゲームの盤面設定およびルール定義",
      "properties": {
        "rat_race": {
          "type": "object",
          "properties": {
            "payday_cells": { 
              "type": "array", 
              "items": { "type": "number" }, 
              "default": [0, 5, 11, 18],
              "description": "給料日マスの位置（0-23）"
            },
            "payday_rule": { 
              "type": "string", 
              "enum": ["passing_or_landing"],
              "description": "通過または着地で発動するルール定義"
            }
          }
        }
      }
    },
    "cards": {
      "type": "array",
      "description": "カードのマスターデータ（JSONファイルおよびSupabaseのcardsテーブルに該当）",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "deck_type": { "type": "string", "enum": ["small_deal", "big_deal", "market", "doodad"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "symbol": { "type": "string", "description": "例: House, Apart(24), MYT4U" },
          "asset_type": { "type": "string", "enum": ["real_estate", "stock", "business", "coin", "none"], "description": "財務諸表の反映カテゴリ" },
          "cost": { "type": "number" },
          "down_payment": { "type": "number" },
          "mortgage": { "type": "number" },
          "passive_income": { "type": "number" },
          "is_resellable": { "type": "boolean", "description": "他プレイヤーへの転売が可能かどうか" },
          "action_rule": {
             "type": ["object", "null"],
             "description": "子供の数での掛け算や株式分割など、特殊な計算ルール",
             "properties": {
                 "type": { "type": "string", "enum": ["multiply_by_child", "stock_split", "stock_reverse_split", "market_sell"] },
                 "target_symbol": { "type": "string" },
                 "multiplier": { "type": "number" }
             }
          }
        },
        "required": ["id", "deck_type", "title", "description"]
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "current_turn_user_id": { "type": ["string", "null"] },
          "game_state": {
            "type": "object",
            "properties": {
              "current_card": {
                "type": ["object", "null"],
                "description": "現在引かれているカードのインスタンス情報",
                "properties": {
                  "status": { "type": "string", "enum": ["active", "completed"] },
                  "owner_user_id": { "type": "string" },
                  "card_id": { "type": "number", "description": "マスターデータのID参照" },
                  "deck_type": { "type": "string", "enum": ["small_deal", "big_deal", "market", "doodad"] },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "symbol": { "type": "string" },
                  "asset_type": { "type": "string" },
                  "cost": { "type": "number" },
                  "down_payment": { "type": "number" },
                  "mortgage": { "type": "number" },
                  "passive_income": { "type": "number" },
                  "is_resellable": { "type": "boolean" },
                  "action_rule": {
                    "type": ["object", "null"],
                    "properties": {
                      "type": { "type": "string" },
                      "target_symbol": { "type": "string" },
                      "multiplier": { "type": "number" }
                    }
                  }
                },
                "required": ["status", "card_id", "deck_type", "title"]
              }
            }
          }
        }
      }
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "room_id": { "type": "string" },
          "user_id": { "type": "string" },
          "state": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string", "enum": ["一般", "ホスト"] },
              "profession": { "type": "string" },
              "track": { "type": "string", "enum": ["rat_race", "fast_track"] },
              "position": { "type": "number", "minimum": 0, "maximum": 23 },
              "last_dice": { 
                "type": "number", 
                "minimum": 0, 
                "maximum": 6,
                "description": "プレイヤーが最後に振ったサイコロの出目。手番開始時（プリロール）に必ず 0 にリセットすること。UI側で >0 の場合は『ポストロール状態』と判定し、同一手番内の不正な再ロールを防止する厳密なトリガーとして運用する。"
              },
              "is_calculating": { 
                "type": "boolean", 
                "description": "財務変動直後の手番ロックフラグ。検証成功でfalseに更新。" 
              },
              "calculation_phase": { 
                "type": "string", 
                "enum": ["income_tax", "payday", "deal", "none"] 
              },
              "children_count": { "type": "number", "minimum": 0, "maximum": 3 },
              "charity_turns_left": { "type": "number", "minimum": 0 },
              "downsized_turns_left": { "type": "number", "minimum": 0 },
              "financials": {
                "type": "object",
                "properties": {
                  "cash": { "type": "number" },
                  "cashflow": { "type": "number" },
                  "income": {
                    "type": "object",
                    "properties": {
                      "salary": { "type": "number" },
                      "passive": { "type": "number" },
                      "total": { "type": "number" }
                    }
                  },
                  "expenses": {
                    "type": "object",
                    "properties": {
                      "taxes": { "type": "number" },
                      "mortgage_payment": { "type": "number" },
                      "car_loan_payment": { "type": "number" },
                      "other": { "type": "number" },
                      "total": { "type": "number" }
                    }
                  },
                  "assets": {
                    "type": "object",
                    "properties": {
                      "stocks": { "type": "object" },
                      "real_estate": { "type": "object" }
                    }
                  },
                  "liabilities": {
                    "type": "object",
                    "properties": {
                      "mortgage": { "type": "number" },
                      "car_loan": { "type": "number" },
                      "retail_debt": { "type": "number" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": ["board_settings", "cards", "rooms", "participants"]
}
