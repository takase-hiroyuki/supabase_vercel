{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cashflow Game Database Schema (Updated v3)",
  "description": "Supabase上のrooms, participants, cardsテーブルの厳密なデータ構造とロジック定義。ホストによる山札シャッフル・ゲームライフサイクル制御対応版。",
  "type": "object",
  "properties": {
    "board_settings": {
      "type": "object",
      "description": "ゲームの盤面設定およびルール定義",
      "properties": {
        "rat_race": {
          "type": "object",
          "properties": {
            "payday_cells": { 
              "type": "array", 
              "items": { "type": "number" }, 
              "default": [0, 5, 11, 18],
              "description": "給料日マスの位置（0-23）"
            },
            "payday_rule": { 
              "type": "string", 
              "enum": ["passing_or_landing"],
              "description": "通過または着地で発動するルール定義"
            }
          }
        }
      }
    },
    "cards": {
      "type": "array",
      "description": "カードのマスターデータ（JSONファイルおよびSupabaseのcardsテーブルに該当）",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "deck_type": { "type": "string", "enum": ["small_deal", "big_deal", "market", "doodad"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "symbol": { "type": ["string", "null"], "description": "例: House, Apart(24), MYT4U" },
          "asset_type": { "type": ["string", "null"], "enum": ["real_estate", "stock", "business", "coin", "none", null], "description": "財務諸表の反映カテゴリ" },
          "cost": { "type": ["number", "null"] },
          "down_payment": { "type": ["number", "null"] },
          "mortgage": { "type": ["number", "null"] },
          "passive_income": { "type": ["number", "null"] },
          "is_resellable": { "type": "boolean", "description": "他プレイヤーへの転売が可能かどうか" },
          "action_rule": {
             "type": ["object", "null"],
             "description": "資産売買以外の特殊な計算・処理ルール（Doodad, Market, Stock等のバリエーションを包含）",
             "properties": {
                 "type": { "type": "string", "enum": ["multiply_by_child", "stock_split", "stock_reverse_split", "market_sell"] },
                 "target_symbol": { "type": "string" },
                 "multiplier": { "type": "number" },
                 "amount": { "type": "number", "description": "Doodad等での支払額/負債額" },
                 "is_loan": { "type": "boolean", "description": "支払いがローン（負債）として計上されるか" },
                 "monthly_payment": { "type": "number", "description": "ローン発生時の月々の支出増加額" },
                 "price": { "type": ["number", "string"], "description": "Marketでの売却価格（固定値、または 'Cost*2' のような計算式）" }
             }
          }
        },
        "required": ["id", "deck_type", "title", "description"]
      }
    },
    "rooms": {
      "type": "array",
      "description": "Supabase上のroomsテーブルのレコード配列",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "current_turn_user_id": { "type": ["string", "null"] },
          "game_state": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "enum": ["waiting", "playing", "ended"],
                "default": "waiting",
                "description": "部屋のライフサイクル状態。waiting=準備中(入室可), playing=進行中(シャッフル完了・新規入室不可), ended=全員退室指示済"
              },
              "decks": {
                "type": "object",
                "description": "ホストが初期化時にシャッフルし、永続化した4つの山札（カードIDの配列）",
                "properties": {
                  "small_deal": { "type": "array", "items": { "type": "number" } },
                  "big_deal": { "type": "array", "items": { "type": "number" } },
                  "market": { "type": "array", "items": { "type": "number" } },
                  "doodad": { "type": "array", "items": { "type": "number" } }
                },
                "required": ["small_deal", "big_deal", "market", "doodad"]
              },
              "graveyard": {
                "type": "object",
                "description": "再シャッフル時に使用する、各デッキの引ききった使用済みカードIDの記録用配列",
                "properties": {
                  "small_deal": { "type": "array", "items": { "type": "number" } },
                  "big_deal": { "type": "array", "items": { "type": "number" } },
                  "market": { "type": "array", "items": { "type": "number" } },
                  "doodad": { "type": "array", "items": { "type": "number" } }
                },
                "required": ["small_deal", "big_deal", "market", "doodad"]
              },
              "current_card": {
                "type": ["object", "null"],
                "description": "現在場にドローされて全員の画面に同期表示されているアクティブなカード情報",
                "properties": {
                  "status": { "type": "string", "enum": ["active", "completed"] },
                  "owner_user_id": { "type": "string" },
                  "card_id": { "type": "number" },
                  "deck_type": { "type": "string", "enum": ["small_deal", "big_deal", "market", "doodad"] },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "symbol": { "type": ["string", "null"] },
                  "asset_type": { "type": ["string", "null"] },
                  "cost": { "type": ["number", "null"] },
                  "down_payment": { "type": ["number", "null"] },
                  "mortgage": { "type": ["number", "null"] },
                  "passive_income": { "type": ["number", "null"] },
                  "is_resellable": { "type": "boolean" },
                  "action_rule": {
                    "type": ["object", "null"],
                    "properties": {
                      "type": { "type": "string" },
                      "target_symbol": { "type": "string" },
                      "multiplier": { "type": "number" },
                      "amount": { "type": "number" },
                      "is_loan": { "type": "boolean" },
                      "monthly_payment": { "type": "number" },
                      "price": { "type": ["number", "string"] }
                    }
                  }
                },
                "required": ["status", "card_id", "deck_type", "title"]
              }
            },
            "required": ["status"]
          }
        },
        "required": ["id", "game_state"]
      }
    },
    "participants": {
      "type": "array",
      "description": "Supabase上のparticipantsテーブルのレコード配列",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "number" },
          "room_id": { "type": "string" },
          "user_id": { "type": "string" },
          "state": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string", "enum": ["general", "host"], "description": "コード側実装(general)とスキーマ記述の完全統合" },
              "profession": { "type": "string" },
              "track": { "type": "string", "enum": ["rat_race", "fast_track"] },
              "position": { "type": "number", "minimum": 0, "maximum": 23 },
              "last_dice": { "type": "number", "minimum": 0, "maximum": 6 },
              "is_calculating": { "type": "boolean", "description": "財務計算のための入力ロック状態フラグ" },
              "calculation_phase": { "type": "string", "enum": ["income_tax", "payday", "deal", "none"] },
              "children_count": { "type": "number", "minimum": 0, "maximum": 3 },
              "charity_turns_left": { "type": "number", "minimum": 0 },
              "downsized_turns_left": { "type": "number", "minimum": 0 },
              "financials": {
                "type": "object",
                "properties": {
                  "cash": { "type": "number" },
                  "cashflow": { "type": "number", "description": "毎月のキャッシュフロー純額(総収入 - 総支出)" },
                  "income": { 
                    "type": "object", 
                    "properties": { 
                      "salary": { "type": "number" }, 
                      "passive": { "type": "number" }, 
                      "total": { "type": "number" } 
                    },
                    "required": ["salary", "passive", "total"]
                  },
                  "expenses": { 
                    "type": "object", 
                    "properties": { 
                      "taxes": { "type": "number" }, 
                      "mortgage_payment": { "type": "number" }, 
                      "car_loan_payment": { "type": "number" }, 
                      "child_expense": { "type": "number", "description": "子供の数 * 職業別子供コストの合計" },
                      "other": { "type": "number" }, 
                      "total": { "type": "number" } 
                    },
                    "required": ["taxes", "total"]
                  },
                  "assets": { 
                    "type": "object", 
                    "properties": { 
                      "stocks": { 
                        "type": "object",
                        "description": "保有株式オブジェクトマップ。キーを銘柄名(symbol)とし、{ count: 数量, average_price: 平均単価 } を格納"
                      }, 
                      "real_estate": { 
                        "type": "array",
                        "description": "保有している不動産・ビジネスオブジェクトの配列。個別売却トリガー対応。"
                      } 
                    },
                    "required": ["stocks", "real_estate"]
                  },
                  "liabilities": { 
                    "type": "object", 
                    "properties": { 
                      "mortgage": { "type": "number" }, 
                      "car_loan": { "type": "number" }, 
                      "retail_debt": { "type": "number" } 
                    },
                    "required": ["mortgage", "car_loan", "retail_debt"]
                  }
                },
                "required": ["cash", "cashflow", "income", "expenses", "assets", "liabilities"]
              }
            },
            "required": ["name", "role", "profession", "track", "position", "last_dice", "is_calculating", "financials"]
          }
        },
        "required": ["room_id", "user_id", "state"]
      }
    }
  },
  "required": ["board_settings", "cards", "rooms", "participants"]
}
