    "last_updated": "2026-07-20",
    "sections": [
      {
        "section_id": "1",
        "title": "システム概要",
        "content": "本システムは、Supabaseをバックエンドに採用した完全リアルタイム同期型の「キャッシュフローゲーム」進行管理システムである。物理的なボードゲームの進行状況、各プレイヤーの財務諸表（PL/BS）、手番の移行、カードイベントの処理をデータベース上で一元管理し、全クライアントへミリ秒単位で同期する。"
      },
      {
        "section_id": "2",
        "title": "システムアーキテクチャ",
        "components": {
          "frontend": "HTML/Vanilla JS (TypeScript互換構成) を用いたSPA（Single Page Application）。UI構築の初期・中期フェーズではCSSを除外する。",
          "backend": "Supabase (PostgreSQL, Realtime API, RPC)。サーバーサイドロジックは全てデータベース層のRPC関数として実装し、クライアントからの直接的なデータ操作をセキュアに制限する。",
          "communication": "WebSocketによるリアルタイム双方向同期（Supabase Realtime）。"
        }
      },
      {
        "section_id": "3",
        "title": "主要機能一覧",
        "features": [
          {
            "name": "ホスト（ゲームマスター）機能",
            "description": "セッション管理、盤面全体のリアルタイム監視、キック制御、カードドローの中央管理。"
          },
          {
            "name": "ゲスト（プレイヤー）機能",
            "description": "ダイスロール、コマ移動、財務諸表（PL/BS）の入力・バリデーション、他プレイヤーの財務状況の参照。"
          },
          {
            "name": "Card Action Dispatcher（カード実行機構）",
            "description": "ドローされたカードのJSONルール（action_rule）を解析し、Doodad（無駄遣い）、Market（市場売却）、Stock（株式分割等）の各ハンドラへ処理を振り分けるロジックエンジン。"
          }
        ]
      },
      {
        "section_id": "4",
        "title": "データベース設計概要",
        "content": "システムは主に3つのテーブルで構成される。マスターデータとなる『cards』、セッションを管理する『rooms』、各プレイヤーの動的状態（財務・現在地・属性など）をJSONB形式で保持する『participants』。詳細なデータ構造および制約はスキーマ定義書（schema.json）に準拠する。"
      },
      {
        "section_id": "5",
        "title": "データアクセス方針及び排他制御",
        "policies": [
          {
            "id": "5.1",
            "title": "リアルタイム・マルチプレイヤー環境における課題と基本原則",
            "content": "本システムは、Supabaseのリアルタイム通信を利用し、複数プレイヤーおよびホストが同時に同一部屋のデータを読み書きする。フロントエンド側で組み立てたオブジェクトをそのまま流し込む完全上書き更新を行うと、ミリ秒単位の競合により他者の最新の更新を過去のデータで巻き戻し破壊するロストアップデートが不可避となる。これを防ぐため、本システムでは「アトミック部分更新原則」を絶対の方針として定義する。"
          },
          {
            "id": "5.2",
            "title": "排他制御・データ更新の具体方針",
            "rules": [
              {
                "rule_id": "5.2.1",
                "item": "JSONB列（state）に対する全体上書き更新の全面禁止",
                "specification": "participantsテーブルのstate列を更新する際、フロントエンドからupdate({ state: newState })のようにオブジェクト全体を送信する処理を全面的に禁止する。"
              },
              {
                "rule_id": "5.2.2",
                "item": "jsonb_set等を用いたアトミックな部分更新の義務化",
                "specification": "特定のステート（手持ちキャッシュ、出目等）のみを変更する場合は、PostgreSQLのjsonb_set演算子、またはマージ演算子を直接SQLまたはSupabaseのRPC経由で発行し、データベース層で直接、差分データのみをアトミックに書き換えること。"
              },
              {
                "rule_id": "5.2.3",
                "item": "手番・状態制御のRPC（ストアドプロシージャ）カプセル化",
                "specification": "「手番終了と次プレイヤーの初期化」や「全員のダイスロック解除」など、複数行や複数テーブルをまたぐ一連のステート遷移は、クライアントサイドでのSELECTしてからUPDATEという分割処理を禁止する。これらはすべてSupabaseのRPCとしてデータベース内部にPL/pgSQL等でカプセル化し、1トランザクションで完結させる。"
              },
              {
                "rule_id": "5.2.4",
                "item": "カードロジック（Dispatcher）実行のトランザクション担保",
                "specification": "Doodadのローン処理に伴う支出・負債の同時更新、およびStockルールの全プレイヤー一斉保有数更新など、Card Action Dispatcherに定義された複雑な財務（PL/BS）変動および波及的再計算（Cascade Updates）は、RPCを用いて1トランザクション内で実行し、計算途中の不完全な状態がRealtime APIで配信されることを防ぐこと。"
              }
            ]
          }
        ]
      }
    ]
  }
}
